{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openriftapp/openrift-data/blob/main/card.schema.json",
  "title": "OpenRift Card Contribution",
  "description": "Schema for a single contributions/*.json file. One file per card.",
  "type": "object",
  "required": ["card", "printings"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "card": { "$ref": "#/$defs/card" },
    "printings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/printing" }
    }
  },
  "$defs": {
    "communityId": {
      "type": "string",
      "pattern": "^community:[A-Za-z0-9][A-Za-z0-9:_-]*$",
      "description": "Must start with 'community:' to namespace from official providers."
    },
    "imageUrl": {
      "type": ["string", "null"],
      "pattern": "^https://",
      "description": "Stable HTTPS link. Don't hotlink riftbound.leagueoflegends.com."
    },
    "card": {
      "type": "object",
      "required": ["name", "external_id"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": ["string", "null"] },
        "super_types": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "domains": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "might": { "type": ["integer", "null"], "minimum": 0 },
        "energy": { "type": ["integer", "null"], "minimum": 0 },
        "power": { "type": ["integer", "null"], "minimum": 0 },
        "might_bonus": { "type": ["integer", "null"], "minimum": 0 },
        "rules_text": { "type": ["string", "null"] },
        "effect_text": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "short_code": { "type": ["string", "null"] },
        "external_id": { "$ref": "#/$defs/communityId" }
      }
    },
    "printing": {
      "type": "object",
      "required": ["short_code", "external_id"],
      "additionalProperties": false,
      "properties": {
        "short_code": { "type": "string", "minLength": 1 },
        "set_id": { "type": ["string", "null"] },
        "set_name": { "type": ["string", "null"] },
        "rarity": { "type": ["string", "null"] },
        "art_variant": { "type": ["string", "null"] },
        "is_signed": { "type": "boolean" },
        "marker_slugs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "distribution_channel_slugs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "finish": { "type": ["string", "null"] },
        "artist": { "type": ["string", "null"] },
        "public_code": { "type": ["string", "null"] },
        "printed_rules_text": { "type": ["string", "null"] },
        "printed_effect_text": { "type": ["string", "null"] },
        "image_url": { "$ref": "#/$defs/imageUrl" },
        "flavor_text": { "type": ["string", "null"] },
        "external_id": { "$ref": "#/$defs/communityId" },
        "language": { "type": ["string", "null"], "maxLength": 5, "pattern": "^[a-z]{2,5}$" },
        "printed_name": { "type": ["string", "null"] }
      }
    }
  }
}
